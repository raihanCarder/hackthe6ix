generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  auth0Sub         String   @unique
  username         String
  email            String?
  avatarUrl        String?
  bio              String   @default("Looking for a hotel for my next")
  wins             Int      @default(0)
  losses           Int      @default(0)
  currentWinStreak Int      @default(0)
  bestWinStreak    Int      @default(0)
  currency         Int      @default(500)
  xp               Int      @default(0)
  level            Int      @default(1)
  packsOpened      Int      @default(0)
  matchesPlayed    Int      @default(0)
  mvpCount         Int      @default(0)
  numberOfKids     Int      @default(0)
  homeCity         String?
  defaultAdults    Int      @default(2)
  lastLoginAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cards          SavedCard[]
  packOpens      PackOpen[]
  cityClaims     CityPackClaim[]
  tournaments    Tournament[]
  apiCalls       Stay22ApiCall[]
  duelsAsPlayer1 Duel[]          @relation("DuelPlayer1")
  duelsAsPlayer2 Duel[]          @relation("DuelPlayer2")
  coinPurchases  CoinPurchase[]
  karaokeDuelsAsPlayer1 KaraokeDuel[] @relation("KaraokeDuelPlayer1")
  karaokeDuelsAsPlayer2 KaraokeDuel[] @relation("KaraokeDuelPlayer2")
}

model Stay22ApiCall {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  endpoint      String
  requestParams Json
  responseBody  Json
  status        Int
  createdAt     DateTime @default(now())

  snapshots   HotelSnapshot[]
  tournaments Tournament[]
  packOpens   PackOpen[]
}

model HotelSnapshot {
  id               String        @id @default(cuid())
  stay22PropertyId String
  sourceApiCallId  String
  sourceApiCall    Stay22ApiCall @relation(fields: [sourceApiCallId], references: [id])
  normalizedData   Json
  createdAt        DateTime      @default(now())

  cards SavedCard[]

  @@index([stay22PropertyId])
  @@index([sourceApiCallId])
}

model PackOpen {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  searchApiCallId  String
  searchApiCall    Stay22ApiCall @relation(fields: [searchApiCallId], references: [id])
  scope            String // "trip" | "global"
  city             String
  cost             Int
  seed             String
  generatedCardIds Json
  createdAt        DateTime      @default(now())
}

model CityPackClaim {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  normalizedCity String
  createdAt      DateTime @default(now())

  @@unique([userId, normalizedCity])
}

model CoinPurchase {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id])
  stripeCheckoutSessionId String    @unique
  stripePaymentIntentId   String?   @unique
  tierId                  String
  coinAmount              Int
  amountCents             Int
  currency                String
  status                  String    @default("pending")
  fulfilledAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([userId])
}

model SavedCard {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  stay22PropertyId String
  snapshotId       String
  snapshot         HotelSnapshot @relation(fields: [snapshotId], references: [id])
  rarity           String // "common" | "rare" | "epic" | "legendary"
  cosmeticSeed     String
  acquiredScope    String
  acquiredCity     String
  edition          Int           @default(1)
  xp               Int           @default(0)
  trophies         Int           @default(0)
  wins             Int           @default(0)
  losses           Int           @default(0)
  timesMvp         Int           @default(0)
  dateAcquired     DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([userId, stay22PropertyId])
}

model Tournament {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  mode                 String // "trip" | "world"
  searchApiCallId      String
  searchApiCall        Stay22ApiCall @relation(fields: [searchApiCallId], references: [id])
  contenderPropertyIds Json
  userCardIds          Json
  questionnaireAnswers Json
  engineResult         Json
  seed                 String
  championPropertyId   String
  bracket              Json
  rewards              Json
  createdAt            DateTime      @default(now())

  presentationRecap PresentationRecap?
}

/// One grounded, reusable full-time report per tournament. Gemini may author
/// the prose, but every input fact is resolved from the stored tournament.
model PresentationRecap {
  tournamentId String     @id
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  caption      String
  source       String // "gemini"
  createdAt    DateTime   @default(now())
}

/// Reusable ElevenLabs output. The cache key includes template, text, voice,
/// model, and format, so a changed input can never return stale commentary.
model PresentationAudio {
  cacheKey       String   @id
  eventType      String
  text           String
  voiceId        String
  modelId        String
  outputFormat   String
  mimeType       String
  audio          Bytes
  characterCount Int
  createdAt      DateTime @default(now())
}

/// Application-side generation ceiling. Cache hits do not consume this budget.
model PresentationUsage {
  period          String   @id // UTC YYYY-MM
  characterCount  Int      @default(0)
  generationCount Int      @default(0)
  updatedAt       DateTime @updatedAt
}

/// Live 1v1 squad duel: waiting-room matchmaking + turn-based, best-of-3
/// stat-call rounds (documentation/ideas/IDEA.md "3-card squad quick-match").
model Duel {
  id             String   @id @default(cuid())
  status         String // "waiting" | "active" | "complete"
  player1Id      String
  player1        User     @relation("DuelPlayer1", fields: [player1Id], references: [id])
  player1CardIds Json // [SavedCard.id, SavedCard.id, SavedCard.id], in play order
  player2Id      String?
  player2        User?    @relation("DuelPlayer2", fields: [player2Id], references: [id])
  player2CardIds Json?
  turnPlayerId   String? // userId who calls the next stat
  rounds         Json     @default("[]")
  player1Wins    Int      @default(0)
  player2Wins    Int      @default(0)
  winnerId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bonusKaraoke KaraokeDuel?

  @@index([status, createdAt])
}

/// Bonus mode, unlocked only after finishing a PvP card Duel, against the same
/// opponent. sourceDuelId pins the pairing to the two players who just
/// finished that Duel, so both players are known immediately — no open
/// matchmaking. Whoever taps "Play Bonus Karaoke Round" first is the
/// inviter (invitedById); the other player must accept before either can
/// pick a hotel ("picking"), after which ElevenLabs writes the songs
/// (see ensureKaraokeReady, which runs once both cards are in). The judge is
/// just a mic: each client measures its own player's sing-along loudness and
/// submits a score — loudest performer wins (see submitKaraokeLoudnessScore).
model KaraokeDuel {
  id                    String   @id @default(cuid())
  status                String // "pending" | "declined" | "picking" | "generating" | "judging" | "complete"
  sourceDuelId          String   @unique
  sourceDuel            Duel     @relation(fields: [sourceDuelId], references: [id])
  invitedById           String // userId who sent the bonus-round invite; the other participant must accept
  player1Id             String
  player1               User     @relation("KaraokeDuelPlayer1", fields: [player1Id], references: [id])
  player1CardId         String? // SavedCard.id — the one hotel they're singing about
  player2Id             String
  player2               User     @relation("KaraokeDuelPlayer2", fields: [player2Id], references: [id])
  player2CardId         String?
  player1Lyrics         String?
  player2Lyrics         String?
  player1AudioCacheKey  String? // KaraokeSongAudio.cacheKey once composed
  player2AudioCacheKey  String?
  player1LoudnessScore  Float? // client-measured mic loudness while singing along, 0-100
  player2LoudnessScore  Float?
  winnerId              String?
  verdict               Json? // { player1Score, player2Score, reasoning }
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, createdAt])
}

/// ElevenLabs Music output, cached the same way as PresentationAudio.
model KaraokeSongAudio {
  cacheKey     String   @id // sha256(modelId, prompt, durationMs, outputFormat)
  prompt       String
  modelId      String
  outputFormat String
  mimeType     String
  audio        Bytes
  durationMs   Int
  createdAt    DateTime @default(now())
}

/// Monthly generation-count ceiling (music isn't billed by character count like TTS).
model KaraokeUsage {
  period          String   @id // UTC YYYY-MM
  generationCount Int      @default(0)
  updatedAt       DateTime @updatedAt
}
