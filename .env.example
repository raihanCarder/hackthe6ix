# Postgres connection (Supabase: Project Settings → Database → Connection string, use the pooler URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:54329/cic"

# Stay22 (server-only; never exposed to the client). Unset = deterministic mock mode.
STAY22_API_KEY=""
STAY22_AFFILIATE_ID=""
STAY22_CAMPAIGN="checkin-champions"
STAY22_API_BASE="https://api.stay22.com"

# Gemini adaptive questions (server-only). Unset = deterministic question bank fallback.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Maximum wait for a personalized question before using the deterministic fallback.
GEMINI_QUESTION_TIMEOUT_MS="1800"

# Optional: Gemini selects among approved commentary lines; it never authors facts.
GEMINI_COMMENTARY_ENABLED="false"

# ElevenLabs presentation audio (server-only). Missing key or voice = caption-only mode.
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL_ID="eleven_flash_v2_5"
ELEVENLABS_OUTPUT_FORMAT="mp3_44100_128"

# Local ceiling plus a protected reserve on the ElevenLabs account.
ELEVENLABS_MONTHLY_CHARACTER_LIMIT="10000"
ELEVENLABS_ACCOUNT_CREDIT_RESERVE="1000"

# Requires user_read permission. Keep false for a text_to_speech-only key.
ELEVENLABS_CHECK_ACCOUNT_QUOTA="false"

# Optional reusable music files, normally served from public/audio.
NEXT_PUBLIC_PRESENTATION_INTRO_MUSIC_URL=""
NEXT_PUBLIC_PRESENTATION_FINAL_MUSIC_URL=""
NEXT_PUBLIC_PRESENTATION_VICTORY_MUSIC_URL=""

# Stripe sandbox coin purchases. Use test keys only for demos.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY="cad"

# Auth0 (unset = local dev sign-in fallback)
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_SECRET="use: openssl rand -hex 32"
APP_BASE_URL="http://localhost:3000"
